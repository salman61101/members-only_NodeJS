<%- include("partials/head", { title }) %>
<%- include("partials/navbar") %>

<main class="page-shell narrow">
    <section class="card form-card">
        <h1>Create Message</h1>
        <%- include("partials/formErrors", { errors }) %>

        <form action="/messages/new" method="POST" class="stack-form">
            <label>
                Title
                <input type="text" name="title" maxlength="120" value="<%= oldData.title || '' %>">
            </label>

            <label>
                Message
                <textarea name="text" rows="6"><%= oldData.text || '' %></textarea>
            </label>

            <button class="button button-primary" type="submit">Post Message</button>
        </form>
    </section>
</main>

<%- include("partials/footer") %>