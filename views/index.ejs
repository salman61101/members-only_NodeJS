<%- include("partials/head", { title }) %>
<%- include("partials/navbar") %>

<main class="page-shell">
	<section class="hero card">
		<div>
			
			<h1>Members Only</h1>
			<p class="hero-copy">
				A private message board for guests, members, and admins.
			</p>
		</div>
		<% if (currentUser) { %>
			<div class="status-panel">
				<span class="status-label">Signed in as</span>
				<strong><%= currentUser.first_name %> <%= currentUser.last_name %></strong>
				<% if (currentUser.is_admin) { %>
					<span class="badge badge-admin">Admin</span>
				<% } else if (currentUser.membership_status) { %>
					<span class="badge badge-member">Member</span>
				<% } else { %>
					<span class="badge badge-guest">Guest</span>
				<% } %>
			</div>
		<% } else { %>
			<div class="status-panel">
				<span class="status-label">Viewing as guest</span>
				<strong>Anonymous reader</strong>
			</div>
		<% } %>
	</section>

	<section class="card stack">
		<div class="section-heading">
			<h2>Messages</h2>
			<% if (currentUser) { %>
				<a class="button button-secondary" href="/messages/new">Create Message</a>
			<% } %>
		</div>

		<% if (messages.length) { %>
			<div class="message-list">
				<% messages.forEach((message) => { %>
					<article class="message-card">
						<header class="message-meta">
							<div>
								<h3><%= message.title %></h3>
								<% if (currentUser && (currentUser.membership_status || currentUser.is_admin)) { %>
									<p class="message-author">
										By <%= message.first_name %> <%= message.last_name %>
									</p>
								<% } else { %>
									<p class="message-author">By Anonymous</p>
								<% } %>
							</div>

							<% if (currentUser && (currentUser.membership_status || currentUser.is_admin)) { %>
								<time class="message-date">
									<%= new Date(message.created_at).toLocaleString("en-US", {
										dateStyle: "medium",
										timeStyle: "short"
									}) %>
								</time>
							<% } %>
						</header>

						<p class="message-text"><%= message.text %></p>

						<% if (currentUser && currentUser.is_admin) { %>
							<form action="/messages/<%= message.id %>/delete" method="POST" class="inline-form">
								<button class="button button-danger" type="submit">Delete</button>
							</form>
						<% } %>
					</article>
				<% }) %>
			</div>
		<% } else { %>
			<p class="empty-state">No messages yet. Be the first to post one.</p>
		<% } %>
	</section>
</main>

<%- include("partials/footer") %>